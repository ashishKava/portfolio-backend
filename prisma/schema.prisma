datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  tags        String   // comma-separated tags (e.g., "React,TypeScript,Express")
  githubUrl   String?
  demoUrl     String?
  imageUrl    String?
  features    String?  // custom list of features, e.g. bullet points separated by newlines or JSON
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(uuid())
  company     String
  role        String
  duration    String   // e.g. "Jun 2023 - Present"
  description String   // markdown or bullet points
  skills      String   // comma-separated skills (e.g., "Node.js,Docker")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
